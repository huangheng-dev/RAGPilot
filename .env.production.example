NODE_ENV=production
NEXT_PUBLIC_GIT_REPOSITORY_URL=https://github.com/your-org/ragpilot

RAGPILOT_WEB_PORT=3000
RAGPILOT_API_PORT=8000
RAGPILOT_TEMPORAL_UI_PORT=8080
RAGPILOT_MINIO_API_PORT=9000
RAGPILOT_MINIO_CONSOLE_PORT=9001
RAGPILOT_POSTGRES_PORT=5432
RAGPILOT_REDIS_PORT=6379
RAGPILOT_ELASTICSEARCH_PORT=9200
RAGPILOT_TEMPORAL_PORT=7233
RAGPILOT_OTEL_GRPC_PORT=4317
RAGPILOT_OTEL_HTTP_PORT=4318
RAGPILOT_OTEL_METRICS_PORT=9464
RAGPILOT_TEMPO_PORT=3200
RAGPILOT_PROMETHEUS_PORT=9090
RAGPILOT_GRAFANA_PORT=3001

POSTGRES_DB=ragpilot
POSTGRES_USER=ragpilot
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
RUNTIME_LIMIT_REDIS_FAILURE_MODE=closed
RUNTIME_LIMIT_CONCURRENCY_LEASE_SECONDS=300

MINIO_ROOT_USER=ragpilot
MINIO_ROOT_PASSWORD=replace-with-strong-password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=ragpilot-documents

ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_RETRIEVAL_ENABLED=true
ELASTICSEARCH_PROJECTION_ENABLED=true
RETRIEVAL_SCORE_NORMALIZATION_STRATEGY=rank_percentile_v1
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_TRACE_SAMPLE_RATIO=0.10
ELASTICSEARCH_INDEX_PREFIX=ragpilot-document-chunks
ELASTICSEARCH_REQUEST_TIMEOUT_SECONDS=5

TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ragpilot-ingestion
AGENT_TEMPORAL_TASK_QUEUE=ragpilot-agent-execution
AGENT_APPROVAL_TIMEOUT_HOURS=24
AGENT_RUNTIME_ENGINE=langgraph_pilot
AGENT_EXECUTION_MAX_TOOL_CALLS=8
AGENT_EXECUTION_MAX_RUNTIME_SECONDS=900
AGENT_EXECUTION_MAX_OUTPUT_BYTES=256000
TEMPORAL_CONNECT_MAX_ATTEMPTS=30
TEMPORAL_CONNECT_RETRY_SECONDS=2
RAGPILOT_API_OPTIONAL_EXTRAS=retrieval-llamaindex,agent-langgraph

EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_MODEL=ragpilot-dev-1536
EMBEDDING_DIMENSION=1536
EMBEDDING_API_BASE_URL=https://embedding-provider.example/v1
EMBEDDING_API_KEY=
EMBEDDING_REQUEST_TIMEOUT_SECONDS=60

CHAT_MODEL_PROVIDER=openai_compatible
CHAT_MODEL_NAME=ragpilot-grounded-template
CHAT_MODEL_API_BASE_URL=https://model-provider.example/v1
CHAT_MODEL_API_KEY=
RUNTIME_CREDENTIAL_MASTER_KEY=replace-with-a-long-random-production-secret
MODEL_RUNTIME_CONCURRENCY_LIMIT=8
MODEL_RUNTIME_REQUESTS_PER_MINUTE=120
MODEL_RUNTIME_MAX_ATTEMPTS=2
MODEL_RUNTIME_RETRY_BACKOFF_SECONDS=0.25
MODEL_RUNTIME_RETRYABLE_STATUS_CODES=429,502,503,504
MODEL_INPUT_COST_PER_1K_TOKENS_USD=0
MODEL_OUTPUT_COST_PER_1K_TOKENS_USD=0
MCP_RUNTIME_CONCURRENCY_LIMIT=16
MCP_RUNTIME_REQUESTS_PER_MINUTE=240
MCP_RUNTIME_MAX_ATTEMPTS=2
MCP_RUNTIME_RETRY_BACKOFF_SECONDS=0.25
CHAT_MODEL_REQUEST_TIMEOUT_SECONDS=180

RETRIEVAL_ENGINE=native
RETRIEVAL_EMBEDDING_MODEL=ragpilot-dev-1536
RETRIEVAL_EMBEDDING_DIMENSION=1536
RETRIEVAL_RERANK_ENABLED=true
RETRIEVAL_RERANK_STRATEGY=native_term_density_v1
RETRIEVAL_RERANK_WINDOW=12

MODEL_PREVIEW_REVIEW_WINDOW_HOURS=24
MCP_PREVIEW_REVIEW_WINDOW_HOURS=24
MCP_RAGPILOT_API_BASE_URL=https://ragpilot.example.com/api/v1
MCP_RAGPILOT_API_KEY=
MCP_RAGPILOT_REQUEST_TIMEOUT_MS=15000
TOOL_PREVIEW_REVIEW_WINDOW_HOURS=24
TOOL_RUNTIME_REQUEST_TIMEOUT_SECONDS=30
TOOL_RUNTIME_MAX_ATTEMPTS=2
TOOL_RUNTIME_RETRYABLE_STATUS_CODES=502,503,504

AUTH_PRIMARY_MODE=password_local
AUTH_PROVIDER_DISPLAY_NAME=Enterprise Identity
AUTH_PROVIDER_SIGN_IN_URL=
AUTH_PROVIDER_POST_SIGN_OUT_URL=
AUTH_FAILED_SIGN_IN_WINDOW_MINUTES=15
AUTH_FAILED_SIGN_IN_MAX_ATTEMPTS=5
AUTH_FAILED_SIGN_IN_LOCKOUT_MINUTES=15
AUTH_SESSION_REVIEW_MAX_ACTIVE_SESSIONS_PER_USER=4
AUTH_SESSION_REVIEW_MAX_DISTINCT_DEVICES_PER_USER=3
ALLOW_LEGACY_ACTOR_HEADERS=false
CORS_ALLOWED_ORIGINS=https://ragpilot.example.com
